<div class="space-y-4" x-data="{ activeIndex: 0 }">
    
    <% if (locals.session && session.globalScoreDelta) { %>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <div class="bg-slate-900 border border-slate-800 p-4 rounded-xl text-center">
                <span class="block text-[10px] uppercase tracking-wider text-slate-500 font-mono">Performance Before</span>
                <span class="text-2xl font-extrabold text-red-400 mt-1 block"><%= session.globalScoreDelta.before %>%</span>
            </div>
            <div class="bg-slate-900 border border-slate-800 p-4 rounded-xl text-center">
                <span class="block text-[10px] uppercase tracking-wider text-slate-500 font-mono">Optimized Engine Index</span>
                <span class="text-2xl font-extrabold text-emerald-400 mt-1 block"><%= session.globalScoreDelta.after %>%</span>
            </div>
            <div class="bg-slate-900 border border-slate-800 p-4 rounded-xl text-center col-span-2">
                <span class="block text-[10px] uppercase tracking-wider text-slate-500 font-mono">Total Remediations Loaded</span>
                <span class="text-2xl font-extrabold text-teal-400 mt-1 block">
                    <%= session.results.reduce((total, page) => total + (page.fixes ? page.fixes.length : 0), 0) %> Core Patches
                </span>
            </div>
        </div>
    <% } %>

    <% if (locals.session && session.globalScoreDelta) { %>
        <div class="bg-slate-900 border border-slate-800 p-6 rounded-2xl shadow-xl space-y-4">
            <h4 class="text-xs font-mono text-slate-400 uppercase tracking-wider flex items-center gap-2">
                <span>📊</span> Simulated Core Web Vitals Improvement
            </h4>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="space-y-1.5">
                    <div class="flex justify-between text-xs font-mono">
                        <span class="text-slate-400">Search Engine Visibility & Tags</span>
                        <span class="text-emerald-400 font-bold">
                            <%= session.globalScoreDelta.before %>% → <%= session.globalScoreDelta.after %>% 
                            (+<%= session.globalScoreDelta.after - session.globalScoreDelta.before %>%)
                        </span>
                    </div>
                    <div class="w-full bg-slate-950 rounded-full h-2 overflow-hidden border border-slate-800">
                        <div class="bg-gradient-to-r from-red-500 via-yellow-500 to-emerald-500 h-2 rounded-full transition-all duration-1000" 
                             style="width: <%= session.globalScoreDelta.after %>%"></div>
                    </div>
                </div>

                <div class="space-y-1.5">
                    <div class="flex justify-between text-xs font-mono">
                        <span class="text-slate-400">Semantic Layout Integrity</span>
                        <span class="text-teal-400 font-bold">
                            <%= Math.min(100, session.globalScoreDelta.before + 15) %>% → 100% 
                            (+<%= 100 - Math.min(100, session.globalScoreDelta.before + 15) %>%)
                        </span>
                    </div>
                    <div class="w-full bg-slate-950 rounded-full h-2 overflow-hidden border border-slate-800">
                        <div class="bg-gradient-to-r from-orange-500 to-teal-400 h-2 rounded-full transition-all duration-1000" 
                             style="width: 100%"></div>
                    </div>
                </div>
            </div>
        </div>
    <% } %>

    <div class="border border-slate-800 bg-slate-900 rounded-2xl overflow-hidden shadow-2xl">
        <div class="border-b border-slate-800 bg-slate-950/40 px-6 py-4 flex flex-wrap items-center justify-between gap-4">
            <div>
                <h3 class="font-bold text-slate-200">Execution Output Summary</h3>
                <p class="text-[11px] text-slate-500 font-mono">Session context index signature: <%= sessionId %></p>
            </div>
            <a href="/api/export/<%= sessionId %>" class="text-xs bg-teal-500 hover:bg-teal-400 text-slate-950 font-bold px-4 py-2 rounded-lg transition shadow-md">
                Download Optimized Build Package (.zip)
            </a>
        </div>

        <div class="grid lg:grid-cols-3 divide-y lg:divide-y-0 lg:divide-x divide-slate-800 min-h-[350px]">
            <div class="bg-slate-950/30 p-2 overflow-y-auto max-h-[450px]">
                <% session.results.forEach((page, index) => { %>
                    <button @click="activeIndex = <%= index %>" 
                            :class="activeIndex === <%= index %> ? 'bg-slate-800 text-teal-400 border-l-2 border-teal-400' : 'text-slate-400 hover:bg-slate-900/50'"
                            class="w-full text-left p-3 rounded-lg text-xs font-mono truncate block transition-all focus:outline-none">
                        / <%= page.url.replace(session.targetUrl, '') || 'index.html' %>
                    </button>
                <% }) %>
            </div>

            <div class="lg:col-span-2 p-6 overflow-y-auto max-h-[450px] bg-slate-900/10">
                <% session.results.forEach((page, index) => { %>
                    <div x-show="activeIndex === <%= index %>" class="space-y-6" style="display: none;">
                        <div>
                            <h4 class="text-xs font-mono uppercase tracking-wider text-slate-400">Automated Remediation Stack</h4>
                            <div class="mt-2 space-y-2">
                                <% if (page.fixes && page.fixes.length > 0) { %>
                                    <% page.fixes.forEach(fix => { %>
                                        <div class="text-xs p-2.5 rounded bg-slate-950 border border-slate-800 flex justify-between items-center gap-4">
                                            <span class="text-cyan-400 font-mono shrink-0">&lt;<%= fix.component %>&gt;</span>
                                            <span class="text-slate-300 flex-1 text-right"><%= fix.detail %></span>
                                            <span class="text-[10px] text-emerald-400 font-mono bg-emerald-500/10 px-2 py-0.5 rounded border border-emerald-500/20 shrink-0">FIXED</span>
                                        </div>
                                    <% }) %>
                                <% } else { %>
                                    <div class="text-xs p-4 rounded bg-slate-950 border border-slate-800 text-slate-500 text-center italic">
                                        No optimization requirements flagged on this route page segment.
                                    </div>
                                <% } %>
                            </div>
                        </div>

                        <!-- <div>
                            <h4 class="text-xs font-mono uppercase tracking-wider text-slate-400 mb-2">Build Output Snapshot Diff Context</h4>
                            <div class="grid md:grid-cols-2 gap-4 font-mono text-[11px]">
                                <div>
                                    <div class="text-red-400 text-[10px] bg-red-500/10 px-2 py-0.5 rounded border border-red-500/20 mb-1 w-max">Before Optimization</div>
                                    <pre class="p-3 bg-slate-950 text-slate-500 border border-slate-800 rounded-lg overflow-x-auto h-40 select-all"><%= page.rawHtml %></pre>
                                </div>
                                <div>
                                    <div class="text-emerald-400 text-[10px] bg-emerald-500/10 px-2 py-0.5 rounded border border-emerald-500/20 mb-1 w-max">Injected Engine Copy</div>
                                    <pre class="p-3 bg-slate-950 text-slate-200 border border-slate-800 rounded-lg overflow-x-auto h-40 select-all"><%= page.optimizedHtml %></pre>
                                </div>
                            </div>
                        </div> -->
                        <div>
    <h4 class="text-xs font-mono uppercase tracking-wider text-slate-400 mb-3 flex items-center gap-2">
        <span>⚡</span> Build Output Snapshot Diff Context
    </h4>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 font-mono text-[11px]">
        
        <div class="flex flex-col rounded-xl overflow-hidden border border-slate-800 bg-slate-950 shadow-inner">
            <div class="bg-slate-900/60 px-3 py-2 border-b border-slate-800/60 flex items-center justify-between">
                <div class="text-red-400 text-[10px] font-bold bg-red-500/10 px-2 py-0.5 rounded border border-red-500/20">
                    Before
                </div>
                <span class="text-[10px] text-slate-600">original index</span>
            </div>
            <!-- <pre class="p-4 text-slate-500 overflow-x-auto h-44 subpixel-antialiased selection:bg-red-500/20 scrollbar-thin scrollbar-thumb-slate-800 select-all leading-relaxed"><%= page.rawHtml %></pre> -->
             <pre class="p-4 text-slate-500 overflow-x-auto h-64 subpixel-antialiased selection:bg-red-500/20 scrollbar-thin scrollbar-thumb-slate-800 select-all leading-relaxed"><%= page.rawHtml %></pre>
        </div>

        <div class="flex flex-col rounded-xl overflow-hidden border border-slate-800 bg-slate-950 shadow-inner">
            <div class="bg-slate-900/60 px-3 py-2 border-b border-slate-800/60 flex items-center justify-between">
                <div class="text-emerald-400 text-[10px] font-bold bg-emerald-500/10 px-2 py-0.5 rounded border border-emerald-500/20">
                    After
                </div>
                <span class="text-[10px] text-slate-500">optimized index</span>
            </div>
            <!-- <pre class="p-4 text-slate-200 overflow-x-auto h-44 subpixel-antialiased selection:bg-emerald-500/20 scrollbar-thin scrollbar-thumb-slate-800 select-all leading-relaxed"><%= page.optimizedHtml %></pre> -->
             <pre class="p-4 text-slate-200 overflow-x-auto h-64 subpixel-antialiased selection:bg-emerald-500/20 scrollbar-thin scrollbar-thumb-slate-800 select-all leading-relaxed"><%= page.optimizedHtml %></pre>
        </div>

    </div>
</div>
                    </div>
                <% }) %>
            </div>
        </div>
    </div>
</div>