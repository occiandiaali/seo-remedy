<div class="space-y-4" x-data="{ activeIndex: 0 }">
    
    <% if (locals.session && session.globalScoreDelta) { %>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <div class="bg-slate-900 border border-slate-800 p-4 rounded-xl text-center">
                <span class="block text-[10px] uppercase tracking-wider text-slate-500 font-mono">Performance Before</span>
                <span class="text-2xl font-extrabold text-red-400 mt-1 block"><%= session.globalScoreDelta.before %>%</span>
            </div>
            <div class="bg-slate-900 border border-slate-800 p-4 rounded-xl text-center">
                <span class="block text-[10px] uppercase tracking-wider text-slate-500 font-mono">Optimized Engine Index</span>
                <span class="text-2xl font-extrabold text-emerald-400 mt-1 block"><%= session.globalScoreDelta.after %>%</span>
            </div>
            <div class="bg-slate-900 border border-slate-800 p-4 rounded-xl text-center col-span-2">
                <span class="block text-[10px] uppercase tracking-wider text-slate-500 font-mono">Total Remediations Loaded</span>
                <span class="text-2xl font-extrabold text-teal-400 mt-1 block">
                    <%= session.results.reduce((total, page) => total + (page.fixes ? page.fixes.length : 0), 0) %> Core Patches
                </span>
            </div>
        </div>
    <% } %>

    <div class="border border-slate-800 bg-slate-900 rounded-2xl overflow-hidden shadow-2xl">
        <div class="border-b border-slate-800 bg-slate-950/40 px-6 py-4 flex flex-wrap items-center justify-between gap-4">
            <div>
                <h3 class="font-bold text-slate-200">Execution Output Summary</h3>
                <p class="text-[11px] text-slate-500 font-mono">Session context index signature: <%= sessionId %></p>
            </div>
            <a href="/api/export/<%= sessionId %>" class="text-xs bg-teal-500 hover:bg-teal-400 text-slate-950 font-bold px-4 py-2 rounded-lg transition shadow-md">
                Download Optimized Build Package (.zip)
            </a>
        </div>

        <div class="grid lg:grid-cols-3 divide-y lg:divide-y-0 lg:divide-x divide-slate-800 min-h-[350px]">
            <div class="bg-slate-950/30 p-2 overflow-y-auto max-h-[450px]">
                <% session.results.forEach((page, index) => { %>
                    <button @click="activeIndex = <%= index %>" 
                            :class="activeIndex === <%= index %> ? 'bg-slate-800 text-teal-400 border-l-2 border-teal-400' : 'text-slate-400 hover:bg-slate-900/50'"
                            class="w-full text-left p-3 rounded-lg text-xs font-mono truncate block transition-all focus:outline-none">
                        / <%= page.url.replace(session.targetUrl, '') || 'index.html' %>
                    </button>
                <% }) %>
            </div>

            <div class="lg:col-span-2 p-6 overflow-y-auto max-h-[450px] bg-slate-900/10">
                <% session.results.forEach((page, index) => { %>
                    <div x-show="activeIndex === <%= index %>" class="space-y-6" style="display: none;">
                        <div>
                            <h4 class="text-xs font-mono uppercase tracking-wider text-slate-400">Automated Remediation Stack</h4>
                            <div class="mt-2 space-y-2">
                                <% if (page.fixes && page.fixes.length > 0) { %>
                                    <% page.fixes.forEach(fix => { %>
                                        <div class="text-xs p-2.5 rounded bg-slate-950 border border-slate-800 flex justify-between items-center gap-4">
                                            <span class="text-cyan-400 font-mono shrink-0">&lt;<%= fix.component %>&gt;</span>
                                            <span class="text-slate-300 flex-1 text-right"><%= fix.detail %></span>
                                            <span class="text-[10px] text-emerald-400 font-mono bg-emerald-500/10 px-2 py-0.5 rounded border border-emerald-500/20 shrink-0">FIXED</span>
                                        </div>
                                    <% }) %>
                                <% } else { %>
                                    <div class="text-xs p-4 rounded bg-slate-950 border border-slate-800 text-slate-500 text-center italic">
                                        No optimization requirements flagged on this route page segment.
                                    </div>
                                <% } %>
                            </div>
                        </div>

