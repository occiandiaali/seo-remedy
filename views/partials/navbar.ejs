<nav class="border-b border-slate-800 bg-slate-900 sticky top-0 z-50 px-4 sm:px-6 py-4">
    <div class="max-w-7xl mx-auto flex items-center justify-between">
        
        <a href="/" id="brand-logo" class="text-xl font-extrabold tracking-tight text-teal-400">
            Remedial.ai
        </a>

        <div class="hidden md:flex items-center gap-6 text-sm font-medium text-slate-300">
            <a href="/#pricing" class="hover:text-teal-400 transition">Pricing</a>
            <a href="/#faqs" class="hover:text-teal-400 transition">FAQs</a>
            <% if (locals.user) { %>
                <a href="/dashboard" class="bg-gradient-to-r from-teal-500 to-cyan-500 text-slate-950 font-semibold px-4 py-2 rounded-lg hover:opacity-90 transition">Console</a>
                <a href="/auth/logout" class="text-slate-400 hover:text-red-400 transition">Logout</a>
            <% } else { %>
                <a href="/auth/login" class="hover:text-slate-100 transition">Sign In</a>
                <a href="/auth/login?register=true" class="bg-slate-800 border border-slate-700 text-slate-100 px-4 py-2 rounded-lg hover:bg-slate-700 transition">Get Started</a>
            <% } %>

            <button type="button" onclick="toggleGlobalTheme()" class="theme-toggle-btn p-2 rounded-lg border border-slate-700 bg-slate-950 text-slate-300 hover:text-teal-400 focus:outline-none">
                <span class="theme-icon">☀️</span>
            </button>
        </div>

        <div class="flex items-center gap-4 md:hidden">
            <button type="button" onclick="toggleGlobalTheme()" class="theme-toggle-btn p-1.5 rounded-lg border border-slate-700 bg-slate-950 text-slate-300 focus:outline-none">
                <span class="theme-icon">☀️</span>
            </button>
            
            <button type="button" onclick="toggleMobileMenu()" class="text-slate-400 hover:text-slate-100 focus:outline-none p-1">
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="#2dd4bf" id="hamburger-icon">
                    <path d="M4 6h16M4 12h16M4 18h16" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/>
                </svg>
            </button>
        </div>
    </div>

    <div id="mobile-drawer" class="hidden mt-4 pt-4 border-t border-slate-800 space-y-3 px-2">
        <a href="/#pricing" onclick="toggleMobileMenu()" class="block text-sm text-slate-300 hover:text-teal-400 py-1">Pricing</a>
        <a href="/#faqs" onclick="toggleMobileMenu()" class="block text-sm text-slate-300 hover:text-teal-400 py-1">FAQs</a>
        <hr class="border-slate-800 my-2">
        <% if (locals.user) { %>
            <a href="/dashboard" class="block text-sm text-teal-400 font-semibold py-1">Console Workspace</a>
            <a href="/auth/logout" class="block text-sm text-red-400 py-1">Logout</a>
        <% } else { %>
            <a href="/auth/login" class="block text-sm text-slate-300 hover:text-slate-100 py-1">Sign In</a>
            <a href="/auth/login?register=true" class="block w-full text-center bg-slate-800 border border-slate-700 text-slate-100 py-2 rounded-lg mt-2">Get Started</a>
        <% } %>
    </div>
</nav>

<script>
    function updateThemeUI() {
        const isLight = document.documentElement.classList.contains('light-theme');
        
        // 1. Synchronize All Toggle Button Icons App-Wide
        document.querySelectorAll('.theme-icon').forEach(el => {
            el.innerText = isLight ? '🌙' : '☀️';
        });

        // 2. Enforce High Contrast Visibility on Logo Text
        const brandLogo = document.getElementById('brand-logo');
        if (brandLogo) {
            brandLogo.style.color = isLight ? '#0f172a' : '#2dd4bf';
        }

        // 3. Fix Mobile Hamburger Icon Color
        const hamburgerSvg = document.getElementById('hamburger-icon');
        if (hamburgerSvg) {
            hamburgerSvg.setAttribute('stroke', isLight ? '#0f172a' : '#2dd4bf');
        }
    }

    function toggleGlobalTheme() {
        const currentIsLight = document.documentElement.classList.toggle('light-theme');
        localStorage.setItem('theme', currentIsLight ? 'light' : 'dark');
        updateThemeUI();
    }

    function toggleMobileMenu() {
        const drawer = document.getElementById('mobile-drawer');
        const hamburgerSvg = document.getElementById('hamburger-icon');
        
        if (drawer.classList.contains('hidden')) {
            drawer.classList.remove('hidden');
            // Transform hamburger into an 'X' icon
            hamburgerSvg.innerHTML = '<path d="M6 18L18 6M6 6l12 12" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/>';
        } else {
            drawer.classList.add('hidden');
            // Revert back to standard lines
            hamburgerSvg.innerHTML = '<path d="M4 6h16M4 12h16M4 18h16" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/>';
        }
    }

    // Run layout adjustments immediately when the DOM tree mounts
    document.addEventListener("DOMContentLoaded", () => {
        if (localStorage.getItem('theme') === 'light') {
            document.documentElement.classList.add('light-theme');
        }
        updateThemeUI();
    });
</script>